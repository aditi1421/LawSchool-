# Anthropic API key for the artifact agent and grounded query
ANTHROPIC_API_KEY=

# Where matter files and extractions are stored (default: data/matters, gitignored)
LAWSCHOOL_DATA_DIR=data/matters

# Comma-separated origins allowed to call this API (default: the Next.js dev server)
LAWSCHOOL_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Postgres (docker compose up -d). Production: managed Postgres, ap-south-1.
DATABASE_URL=postgresql+psycopg://lawschool:lawschool@localhost:5433/lawschool
